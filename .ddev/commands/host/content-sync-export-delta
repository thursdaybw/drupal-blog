#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Export all missing+changed bb_ai_listing graphs from dev against target.
## Usage: content-sync-export-delta [--target=staging|prod] [--limit=<n>] [--dry-run]
## Example: ddev content-sync-export-delta --target=staging

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
TARGET="staging"
LIMIT=""
DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --target=staging|--target=prod)
      TARGET="${arg#*=}"
      ;;
    --limit=*)
      LIMIT="${arg#*=}"
      if ! [[ "${LIMIT}" =~ ^[0-9]+$ ]]; then
        echo "Invalid --limit value: ${LIMIT}"
        exit 1
      fi
      ;;
    --dry-run)
      DRY_RUN=true
      ;;
    *)
      echo "Unknown argument: ${arg}"
      exit 1
      ;;
  esac
done

if [ "${TARGET}" = "staging" ]; then
  REMOTE_WORKSPACE="/home/bevan/workspace/bb-platform-staging"
else
  REMOTE_WORKSPACE="/home/bevan/workspace/bb-platform-prod"
fi

SSH_TARGET="bb-drupal-prod"
REMOTE_COMPOSE_PATH="${REMOTE_WORKSPACE}/docker-compose.yml"
REMOTE_ENV_PATH="${REMOTE_WORKSPACE}/.env"
DRUSH_BIN="../vendor/bin/drush"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "${TMP_DIR}"' EXIT

LOCAL_MAP="${TMP_DIR}/local_map.tsv"
REMOTE_MAP="${TMP_DIR}/remote_map.tsv"
DELTA_MAP="${TMP_DIR}/delta.tsv"
MAP_LIMIT_ARG=""

if [ -n "${LIMIT}" ]; then
  MAP_LIMIT_ARG=" --limit=${LIMIT}"
fi

echo "Export delta phase (dev -> ${TARGET})"
echo "- dry run: ${DRY_RUN}"
echo "- limit: ${LIMIT:-none}"

if ! ssh "${SSH_TARGET}" "sudo -n docker compose -f ${REMOTE_COMPOSE_PATH} --env-file ${REMOTE_ENV_PATH} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x ${DRUSH_BIN} ]; then echo Drush_not_found >&2; exit 127; fi; ${DRUSH_BIN} list'" | grep -q "bb-ai-listing-sync:fingerprint-map"; then
  echo "Remote ${TARGET} does not have bb-ai-listing-sync:fingerprint-map yet."
  echo "Deploy current code to ${TARGET} first, then rerun this command."
  exit 1
fi

echo "Building fingerprint maps in parallel (dev + ${TARGET})..."
ddev drush bb-ai-listing-sync:fingerprint-map --format=tsv${MAP_LIMIT_ARG} > "${LOCAL_MAP}" &
LOCAL_PID=$!

ssh "${SSH_TARGET}" "sudo -n docker compose -f ${REMOTE_COMPOSE_PATH} --env-file ${REMOTE_ENV_PATH} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x ${DRUSH_BIN} ]; then echo Drush_not_found >&2; exit 127; fi; ${DRUSH_BIN} bb-ai-listing-sync:fingerprint-map --format=tsv${MAP_LIMIT_ARG}'" > "${REMOTE_MAP}" &
REMOTE_PID=$!

LOCAL_EXIT=0
REMOTE_EXIT=0
wait "${LOCAL_PID}" || LOCAL_EXIT=$?
wait "${REMOTE_PID}" || REMOTE_EXIT=$?

if [ "${LOCAL_EXIT}" -ne 0 ]; then
  echo "Failed to build local fingerprint map (exit ${LOCAL_EXIT})."
  exit "${LOCAL_EXIT}"
fi

if [ "${REMOTE_EXIT}" -ne 0 ]; then
  echo "Failed to build remote fingerprint map for ${TARGET} (exit ${REMOTE_EXIT})."
  exit "${REMOTE_EXIT}"
fi

awk -F '\t' '
  NR==FNR {
    remote_uuid[$2] = 1
    remote_fp[$2] = $6
    next
  }
  {
    id = $1
    uuid = $2
    local_fp = $6
    if (!(uuid in remote_uuid)) {
      print "missing\t" id "\t" uuid
      next
    }
    if (remote_fp[uuid] != local_fp) {
      print "changed\t" id "\t" uuid
    }
  }
' "${REMOTE_MAP}" "${LOCAL_MAP}" > "${DELTA_MAP}"

TOTAL_DELTA=$(wc -l < "${DELTA_MAP}" | tr -d ' ')
if [ "${TOTAL_DELTA}" -eq 0 ]; then
  echo "No missing or changed listings to export."
  exit 0
fi

echo "Preparing content/sync output directory..."
if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] clear ${PROJECT_ROOT}/content/sync/entities and ${PROJECT_ROOT}/content/sync/files"
else
  mkdir -p "${PROJECT_ROOT}/content/sync/entities" "${PROJECT_ROOT}/content/sync/files"
  find "${PROJECT_ROOT}/content/sync/entities" -mindepth 1 -delete
  find "${PROJECT_ROOT}/content/sync/files" -mindepth 1 -delete
fi

echo "Exporting ${TOTAL_DELTA} listing graph(s)..."
EXPORTED_COUNT=0
while IFS=$'\t' read -r delta_type listing_id listing_uuid; do
  if [ "${DRY_RUN}" = true ]; then
    echo "[dry-run] ddev drush bb-ai-listing-sync:export ${listing_id}   # ${delta_type} ${listing_uuid}"
    EXPORTED_COUNT=$((EXPORTED_COUNT + 1))
    continue
  fi

  echo "- exporting listing ${listing_id} (${delta_type})"
  # Prevent drush from consuming the while-loop input stream.
  ddev drush bb-ai-listing-sync:export "${listing_id}" </dev/null
  EXPORTED_COUNT=$((EXPORTED_COUNT + 1))
done < "${DELTA_MAP}"

echo "Delta export complete."
echo "- listings exported: ${EXPORTED_COUNT}"
if [ "${EXPORTED_COUNT}" -ne "${TOTAL_DELTA}" ]; then
  echo "- expected delta rows: ${TOTAL_DELTA}"
  echo "WARNING: exported count does not match delta row count."
fi
echo "- output: ${PROJECT_ROOT}/content/sync"
