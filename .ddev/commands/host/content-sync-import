#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Import staged content-sync files into target Drupal environment.
## Usage: content-sync-import [--target=staging|prod] [--label=sync] [--entity-types=a,b] [--uuids=u1,u2] [--actions=create,update|create,update,delete] [--skiplist] [--compare-dates] [--dry-run]
## Example: ddev content-sync-import --target=staging --actions=create,update

SSH_TARGET="bb-drupal-prod"
TARGET="staging"
DRY_RUN=false
LABEL="sync"
ENTITY_TYPES=""
UUIDS=""
ACTIONS="create,update"
SKIPLIST=false
COMPARE_DATES=false
# Update this one constant if drush location changes in the container.
DRUSH_BIN="../vendor/bin/drush"
CONTAINER_CONTENT_DIR_DEFAULT="/var/www/content/sync"
CONTAINER_CONTENT_DIR="${CONTAINER_CONTENT_DIR_DEFAULT}"

for arg in "$@"; do
  case "$arg" in
    --target=staging|--target=prod)
      TARGET="${arg#*=}"
      ;;
    --dry-run)
      DRY_RUN=true
      ;;
    --label=*)
      LABEL="${arg#*=}"
      ;;
    --entity-types=*)
      ENTITY_TYPES="${arg#*=}"
      ;;
    --uuids=*)
      UUIDS="${arg#*=}"
      ;;
    --actions=*)
      ACTIONS="${arg#*=}"
      ;;
    --skiplist)
      SKIPLIST=true
      ;;
    --compare-dates)
      COMPARE_DATES=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

if [ "${TARGET}" = "staging" ]; then
  WORKSPACE="/home/bevan/workspace/bb-platform-staging"
else
  WORKSPACE="/home/bevan/workspace/bb-platform-prod"
fi

COMPOSE_PATH="${WORKSPACE}/docker-compose.yml"
ENV_PATH="${WORKSPACE}/.env"
REMOTE_CONTENT_DIR="${WORKSPACE}/content/sync"

read -r -d '' COMPOSE_PREFIX <<COMPOSE || true
sudo -n docker compose -f ${COMPOSE_PATH} --env-file ${ENV_PATH}
COMPOSE

IMPORT_CMD="${DRUSH_BIN} content-sync:import ${LABEL} -y"

if [ -n "${ENTITY_TYPES}" ]; then
  IMPORT_CMD+=" --entity-types=${ENTITY_TYPES}"
fi

if [ -n "${UUIDS}" ]; then
  IMPORT_CMD+=" --uuids=${UUIDS}"
fi

IMPORT_CMD+=" --actions=${ACTIONS}"

if [ "${SKIPLIST}" = true ]; then
  IMPORT_CMD+=" --skiplist"
fi

if [ "${COMPARE_DATES}" = true ]; then
  IMPORT_CMD+=" --compare-dates"
fi

echo "Content import phase (${TARGET})"
echo "- source on remote host: ${REMOTE_CONTENT_DIR}"
echo "- target in container: ${CONTAINER_CONTENT_DIR}"
echo "- drush bin: ${DRUSH_BIN}"
echo "- drush command: ${IMPORT_CMD}"
echo "- dry run: ${DRY_RUN}"

if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] ssh ${SSH_TARGET} '${COMPOSE_PREFIX} ps -q appserver'"
  echo "[dry-run] ssh ${SSH_TARGET} '${COMPOSE_PREFIX} up -d appserver'"
  echo "[dry-run] ssh ${SSH_TARGET} '${COMPOSE_PREFIX} ps -q appserver'"
  echo "[dry-run] ssh ${SSH_TARGET} 'sudo -n docker cp ${REMOTE_CONTENT_DIR}/. <app_container_id>:${CONTAINER_CONTENT_DIR}/'"
  echo "[dry-run] ssh ${SSH_TARGET} '${COMPOSE_PREFIX} exec -T appserver sh -lc \"cd /var/www/html && ${IMPORT_CMD}\"'"
  exit 0
fi

APP_CONTAINER_ID="$(ssh "${SSH_TARGET}" "${COMPOSE_PREFIX} ps -q appserver")"

if [ -z "${APP_CONTAINER_ID}" ]; then
  ssh "${SSH_TARGET}" "${COMPOSE_PREFIX} up -d appserver"
  APP_CONTAINER_ID="$(ssh "${SSH_TARGET}" "${COMPOSE_PREFIX} ps -q appserver")"
fi

if [ -z "${APP_CONTAINER_ID}" ]; then
  echo "Could not resolve ${TARGET} appserver container id."
  exit 1
fi

resolve_container_content_dir() {
  local resolved_dir
  resolved_dir="$(ssh "${SSH_TARGET}" "${COMPOSE_PREFIX} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x \"${DRUSH_BIN}\" ]; then exit 127; fi; ${DRUSH_BIN} ev \"if (function_exists(\\\"content_sync_get_content_directory\\\")) { echo content_sync_get_content_directory(\\\"${LABEL}\\\"); }\" 2>/dev/null'" || true)"
  resolved_dir="$(printf '%s' "${resolved_dir}" | tr -d '\r' | tail -n 1)"
  if [ -n "${resolved_dir}" ]; then
    printf '%s' "${resolved_dir}"
    return
  fi
  printf '%s' "${CONTAINER_CONTENT_DIR_DEFAULT}"
}

CONTAINER_CONTENT_DIR="$(resolve_container_content_dir)"

echo "Resolved container sync directory: ${CONTAINER_CONTENT_DIR}"

ssh "${SSH_TARGET}" "test -d ${REMOTE_CONTENT_DIR}"
ssh "${SSH_TARGET}" "sudo -n docker exec ${APP_CONTAINER_ID} mkdir -p ${CONTAINER_CONTENT_DIR}"
ssh "${SSH_TARGET}" "sudo -n docker cp ${REMOTE_CONTENT_DIR}/. ${APP_CONTAINER_ID}:${CONTAINER_CONTENT_DIR}/"
ssh "${SSH_TARGET}" "${COMPOSE_PREFIX} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x \"${DRUSH_BIN}\" ]; then echo \"Drush binary not found: ${DRUSH_BIN}\"; exit 127; fi; ${DRUSH_BIN} content-sync:import ${LABEL} -y${ENTITY_TYPES:+ --entity-types=${ENTITY_TYPES}}${UUIDS:+ --uuids=${UUIDS}}${ACTIONS:+ --actions=${ACTIONS}}$( [ \"${SKIPLIST}\" = true ] && printf ' --skiplist' )$( [ \"${COMPARE_DATES}\" = true ] && printf ' --compare-dates' )'"

echo "Content import complete (${TARGET})."
