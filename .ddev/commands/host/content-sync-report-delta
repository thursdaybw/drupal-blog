#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Generate bb_ai_listing delta report (missing + changed) from dev to target.
## Usage: content-sync-report-delta [--target=staging|prod] [--limit=<n>] [--show-uuids]
## Example: ddev content-sync-report-delta --target=staging --show-uuids

TARGET="staging"
LIMIT=""
SHOW_UUIDS=false

for arg in "$@"; do
  case "$arg" in
    --target=staging|--target=prod)
      TARGET="${arg#*=}"
      ;;
    --limit=*)
      LIMIT="${arg#*=}"
      if ! [[ "${LIMIT}" =~ ^[0-9]+$ ]]; then
        echo "Invalid --limit value: ${LIMIT}"
        exit 1
      fi
      ;;
    --show-uuids)
      SHOW_UUIDS=true
      ;;
    *)
      echo "Unknown argument: ${arg}"
      exit 1
      ;;
  esac
done

if [ "${TARGET}" = "staging" ]; then
  REMOTE_WORKSPACE="/home/bevan/workspace/bb-platform-staging"
else
  REMOTE_WORKSPACE="/home/bevan/workspace/bb-platform-prod"
fi

SSH_TARGET="bb-drupal-prod"
REMOTE_COMPOSE_PATH="${REMOTE_WORKSPACE}/docker-compose.yml"
REMOTE_ENV_PATH="${REMOTE_WORKSPACE}/.env"
DRUSH_BIN="../vendor/bin/drush"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "${TMP_DIR}"' EXIT

LOCAL_MAP="${TMP_DIR}/local_map.tsv"
REMOTE_MAP="${TMP_DIR}/remote_map.tsv"
DELTA_MAP="${TMP_DIR}/delta.tsv"
MAP_LIMIT_ARG=""

if [ -n "${LIMIT}" ]; then
  MAP_LIMIT_ARG=" --limit=${LIMIT}"
fi

if ! ssh "${SSH_TARGET}" "sudo -n docker compose -f ${REMOTE_COMPOSE_PATH} --env-file ${REMOTE_ENV_PATH} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x ${DRUSH_BIN} ]; then echo Drush_not_found >&2; exit 127; fi; ${DRUSH_BIN} list'" | grep -q "bb-ai-listing-sync:fingerprint-map"; then
  echo "Remote ${TARGET} does not have bb-ai-listing-sync:fingerprint-map yet."
  echo "Deploy current code to ${TARGET} first, then rerun this command."
  exit 1
fi

echo "Building fingerprint maps in parallel (dev + ${TARGET})..."
ddev drush bb-ai-listing-sync:fingerprint-map --format=tsv${MAP_LIMIT_ARG} > "${LOCAL_MAP}" &
LOCAL_PID=$!

ssh "${SSH_TARGET}" "sudo -n docker compose -f ${REMOTE_COMPOSE_PATH} --env-file ${REMOTE_ENV_PATH} exec -T appserver sh -lc 'cd /var/www/html && if [ ! -x ${DRUSH_BIN} ]; then echo Drush_not_found >&2; exit 127; fi; ${DRUSH_BIN} bb-ai-listing-sync:fingerprint-map --format=tsv${MAP_LIMIT_ARG}'" > "${REMOTE_MAP}" &
REMOTE_PID=$!

LOCAL_EXIT=0
REMOTE_EXIT=0
wait "${LOCAL_PID}" || LOCAL_EXIT=$?
wait "${REMOTE_PID}" || REMOTE_EXIT=$?

if [ "${LOCAL_EXIT}" -ne 0 ]; then
  echo "Failed to build local fingerprint map (exit ${LOCAL_EXIT})."
  exit "${LOCAL_EXIT}"
fi

if [ "${REMOTE_EXIT}" -ne 0 ]; then
  echo "Failed to build remote fingerprint map for ${TARGET} (exit ${REMOTE_EXIT})."
  exit "${REMOTE_EXIT}"
fi

awk -F '\t' '
  NR==FNR {
    remote_uuid[$2] = 1
    remote_fp[$2] = $6
    next
  }
  {
    id = $1
    uuid = $2
    status = $3
    changed = $4
    title = $5
    local_fp = $6

    if (!(uuid in remote_uuid)) {
      print "missing\t" id "\t" uuid "\t" status "\t" changed "\t" title "\t" local_fp
      next
    }

    if (remote_fp[uuid] != local_fp) {
      print "changed\t" id "\t" uuid "\t" status "\t" changed "\t" title "\t" local_fp
    }
  }
' "${REMOTE_MAP}" "${LOCAL_MAP}" > "${DELTA_MAP}"

TOTAL_LOCAL=$(wc -l < "${LOCAL_MAP}" | tr -d ' ')
TOTAL_REMOTE=$(wc -l < "${REMOTE_MAP}" | tr -d ' ')
TOTAL_DELTA=$(wc -l < "${DELTA_MAP}" | tr -d ' ')
TOTAL_MISSING=$(awk -F '\t' '$1 == "missing" {count++} END {print count+0}' "${DELTA_MAP}")
TOTAL_CHANGED=$(awk -F '\t' '$1 == "changed" {count++} END {print count+0}' "${DELTA_MAP}")

echo
echo "Delta report: dev -> ${TARGET}"
echo "- local listings: ${TOTAL_LOCAL}"
echo "- remote listings: ${TOTAL_REMOTE}"
echo "- delta total: ${TOTAL_DELTA}"
echo "- missing on ${TARGET}: ${TOTAL_MISSING}"
echo "- changed on ${TARGET}: ${TOTAL_CHANGED}"

if [ "${TOTAL_DELTA}" -eq 0 ]; then
  echo
  echo "No missing or changed listings."
  exit 0
fi

echo
printf "%-8s %-8s %-38s %-14s %-12s %s\n" "TYPE" "ID" "UUID" "STATUS" "CHANGED" "LABEL"
printf "%-8s %-8s %-38s %-14s %-12s %s\n" "--------" "--------" "--------------------------------------" "--------------" "------------" "----------------------------------------"

awk -F '\t' '
  {
    printf "%-8s %-8s %-38s %-14s %-12s %s\n", $1, $2, $3, $4, $5, $6
  }
' "${DELTA_MAP}"

if [ "${SHOW_UUIDS}" = true ]; then
  echo
  echo "Delta UUID list:"
  awk -F '\t' '{print $3}' "${DELTA_MAP}" | paste -sd, -
fi
