#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Build, upload, and activate a production release.
## Usage: deploy [--dry-run] [--image-tag=<tag>]
## Example: ddev deploy --dry-run

DRY_RUN=false
IMAGE_TAG_ARG=""

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --image-tag=*)
      IMAGE_TAG_ARG="$arg"
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

BUILD_ARGS=()
COMMON_ARGS=()

if [ -n "${IMAGE_TAG_ARG}" ]; then
  BUILD_ARGS+=("${IMAGE_TAG_ARG}")
fi

if [ "${DRY_RUN}" = true ]; then
  BUILD_ARGS+=("--dry-run")
  COMMON_ARGS+=("--dry-run")
fi

echo "Deploy phases: build -> upload -> activate"

"$(dirname "$0")/deploy-build" "${BUILD_ARGS[@]}"
"$(dirname "$0")/deploy-upload" "${COMMON_ARGS[@]}"
"$(dirname "$0")/deploy-activate" "${COMMON_ARGS[@]}"

echo "Deployment pipeline complete."
