#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Build production image on the VPS build environment.
## Usage: deploy-build [--dry-run] [--image-tag=<tag>] [--force-rebuild]
## Example: ddev deploy-build --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
LOCAL_ARTIFACT_DIR="${PROJECT_ROOT}/.ddev/.artifacts"
RELEASE_ENV_PATH="${LOCAL_ARTIFACT_DIR}/release.env"
IMAGE_REPOSITORY="bb-platform-drupal"
REMOTE_RELEASE_DIR="/home/bevan/workspace/bb-platform-prod/releases"
SSH_TARGET="bb-drupal-prod"
REMOTE_BUILD_WORKSPACE="/home/bevan/build/bevansbench.com.au"
REMOTE_COMPOSER_HOME="/home/bevan/build/.composer"
REMOTE_COMPOSER_PATH="/home/bevan/build/tools/composer"
REMOTE_GIT_KEY_PATH="/home/bevan/.ssh/bevansbench-drupal_support"

DRY_RUN=false
FORCE_REBUILD=false
IMAGE_TAG_OVERRIDE=""

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --image-tag=*)
      IMAGE_TAG_OVERRIDE="${arg#*=}"
      ;;
    --force-rebuild)
      FORCE_REBUILD=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

fail() {
  echo "$1" >&2
  exit 1
}

resolve_git_context() {
  HEAD_FULL_SHA="$(git -C "${PROJECT_ROOT}" rev-parse HEAD)"
  HEAD_SHORT_SHA="$(git -C "${PROJECT_ROOT}" rev-parse --short=12 HEAD)"
  GIT_BRANCH="$(git -C "${PROJECT_ROOT}" rev-parse --abbrev-ref HEAD)"

  if [ -n "$(git -C "${PROJECT_ROOT}" status --short --untracked-files=no)" ]; then
    WORKING_TREE_DIRTY=true
  else
    WORKING_TREE_DIRTY=false
  fi

  ORIGIN_MAIN_SHA=""
  HEAD_VS_ORIGIN="origin/main unavailable"
  AHEAD_COUNT=0
  BEHIND_COUNT=0
  if git -C "${PROJECT_ROOT}" rev-parse --verify origin/main >/dev/null 2>&1; then
    ORIGIN_MAIN_SHA="$(git -C "${PROJECT_ROOT}" rev-parse origin/main)"
    local counts
    counts="$(git -C "${PROJECT_ROOT}" rev-list --left-right --count HEAD...origin/main)"
    AHEAD_COUNT="${counts%%$'\t'*}"
    BEHIND_COUNT="${counts##*$'\t'}"
    if [ "${AHEAD_COUNT}" -gt 0 ] && [ "${BEHIND_COUNT}" -gt 0 ]; then
      HEAD_VS_ORIGIN="diverged (+${AHEAD_COUNT}/-${BEHIND_COUNT})"
    elif [ "${AHEAD_COUNT}" -gt 0 ]; then
      HEAD_VS_ORIGIN="ahead (+${AHEAD_COUNT})"
    elif [ "${BEHIND_COUNT}" -gt 0 ]; then
      HEAD_VS_ORIGIN="behind (-${BEHIND_COUNT})"
    else
      HEAD_VS_ORIGIN="equal"
    fi
  fi
}

print_git_context() {
  echo "- pwd: $(pwd)"
  echo "- project root: ${PROJECT_ROOT}"
  echo "- git branch: ${GIT_BRANCH}"
  echo "- git HEAD: ${HEAD_FULL_SHA}"
  echo "- git HEAD short: ${HEAD_SHORT_SHA}"
  echo "- working tree dirty: ${WORKING_TREE_DIRTY}"
  if [ -n "${ORIGIN_MAIN_SHA}" ]; then
    echo "- origin/main: ${ORIGIN_MAIN_SHA}"
    echo "- HEAD vs origin/main: ${HEAD_VS_ORIGIN}"
  else
    echo "- origin/main: unavailable"
  fi
}

resolve_artifact_context() {
  EXPECTED_IMAGE_TAG="git-${HEAD_SHORT_SHA}"
  if [ -n "${IMAGE_TAG_OVERRIDE}" ] && [ "${IMAGE_TAG_OVERRIDE}" != "${EXPECTED_IMAGE_TAG}" ]; then
    fail "Build phase aborted. Current HEAD expects image tag ${EXPECTED_IMAGE_TAG}, but explicit --image-tag requested ${IMAGE_TAG_OVERRIDE}."
  fi

  IMAGE_TAG="${EXPECTED_IMAGE_TAG}"
  IMAGE_REF="${IMAGE_REPOSITORY}:${IMAGE_TAG}"
  ARTIFACT_FILE="${IMAGE_REPOSITORY}-${IMAGE_TAG}.tar.gz"
  LOCAL_ARTIFACT_PATH="${LOCAL_ARTIFACT_DIR}/${ARTIFACT_FILE}"
  LOCAL_METADATA_PATH="${LOCAL_ARTIFACT_PATH%.tar.gz}.meta"
  REMOTE_ARTIFACT_PATH="${REMOTE_RELEASE_DIR}/${ARTIFACT_FILE}"
}

write_kv_file() {
  local output_path="$1"
  shift
  while [ "$#" -gt 0 ]; do
    local key="$1"
    local value="$2"
    printf '%s=%q\n' "${key}" "${value}" >> "${output_path}"
    shift 2
  done
}

write_release_env() {
  mkdir -p "${LOCAL_ARTIFACT_DIR}"
  printf '# Generated by ddev deploy-build\n' > "${RELEASE_ENV_PATH}"
  write_kv_file "${RELEASE_ENV_PATH}" \
    PROJECT_ROOT "${PROJECT_ROOT}" \
    IMAGE_REPOSITORY "${IMAGE_REPOSITORY}" \
    IMAGE_TAG "${IMAGE_TAG}" \
    IMAGE_REF "${IMAGE_REF}" \
    ARTIFACT_FILE "${ARTIFACT_FILE}" \
    LOCAL_ARTIFACT_PATH "${LOCAL_ARTIFACT_PATH}" \
    LOCAL_METADATA_PATH "${LOCAL_METADATA_PATH}" \
    REMOTE_RELEASE_DIR "${REMOTE_RELEASE_DIR}" \
    REMOTE_ARTIFACT_PATH "${REMOTE_ARTIFACT_PATH}" \
    REMOTE_BUILD_WORKSPACE "${REMOTE_BUILD_WORKSPACE}" \
    REMOTE_COMPOSER_HOME "${REMOTE_COMPOSER_HOME}" \
    REMOTE_COMPOSER_PATH "${REMOTE_COMPOSER_PATH}" \
    REMOTE_GIT_KEY_PATH "${REMOTE_GIT_KEY_PATH}" \
    HEAD_FULL_SHA "${HEAD_FULL_SHA}" \
    HEAD_SHORT_SHA "${HEAD_SHORT_SHA}" \
    GIT_BRANCH "${GIT_BRANCH}" \
    WORKING_TREE_DIRTY "${WORKING_TREE_DIRTY}" \
    ORIGIN_MAIN_SHA "${ORIGIN_MAIN_SHA}" \
    HEAD_VS_ORIGIN "${HEAD_VS_ORIGIN}"
}

write_build_metadata() {
  : > "${LOCAL_METADATA_PATH}"
  write_kv_file "${LOCAL_METADATA_PATH}" \
    HEAD_FULL_SHA "${HEAD_FULL_SHA}" \
    HEAD_SHORT_SHA "${HEAD_SHORT_SHA}" \
    IMAGE_TAG "${IMAGE_TAG}" \
    IMAGE_REF "${IMAGE_REF}" \
    PROJECT_ROOT "${PROJECT_ROOT}" \
    BUILD_TIME "$(date -Iseconds)" \
    BUILD_LOCATION "remote-vps" \
    REMOTE_BUILD_WORKSPACE "${REMOTE_BUILD_WORKSPACE}" \
    REMOTE_COMPOSER_HOME "${REMOTE_COMPOSER_HOME}" \
    REMOTE_COMPOSER_PATH "${REMOTE_COMPOSER_PATH}" \
    REMOTE_GIT_KEY_PATH "${REMOTE_GIT_KEY_PATH}" \
    GIT_BRANCH "${GIT_BRANCH}" \
    WORKING_TREE_DIRTY "${WORKING_TREE_DIRTY}" \
    ORIGIN_MAIN_SHA "${ORIGIN_MAIN_SHA}" \
    HEAD_VS_ORIGIN "${HEAD_VS_ORIGIN}" \
    ARTIFACT_FILE "${ARTIFACT_FILE}" \
    LOCAL_ARTIFACT_PATH "${LOCAL_ARTIFACT_PATH}"
}

remote_image_exists() {
  ssh "${SSH_TARGET}" "sudo -n docker image inspect '${IMAGE_REF}' >/dev/null 2>&1"
}

run_remote_build() {
  ssh "${SSH_TARGET}" "
set -euo pipefail
export GIT_SSH_COMMAND='ssh -i ${REMOTE_GIT_KEY_PATH} -o IdentitiesOnly=yes'
cd '${REMOTE_BUILD_WORKSPACE}'
git fetch --all --tags --prune
git checkout --force '${HEAD_FULL_SHA}'
git submodule sync --recursive
git submodule update --init --recursive
COMPOSER_HOME='${REMOTE_COMPOSER_HOME}' '${REMOTE_COMPOSER_PATH}' install --no-interaction --prefer-dist
sudo -n docker build -t '${IMAGE_REF}' -f Dockerfile.prod .
"
}

print_plan() {
  echo "Build phase"
  print_git_context
  echo "- image: ${IMAGE_REF}"
  echo "- build host: ${SSH_TARGET}"
  echo "- build workspace: ${REMOTE_BUILD_WORKSPACE}"
  echo "- composer: ${REMOTE_COMPOSER_PATH}"
  echo "- metadata: ${LOCAL_METADATA_PATH}"
  echo "- release env: ${RELEASE_ENV_PATH}"
  echo "- dry run: ${DRY_RUN}"
  echo "- force rebuild: ${FORCE_REBUILD}"
}

resolve_git_context
resolve_artifact_context
print_plan
write_release_env
write_build_metadata

if [ "${DRY_RUN}" = true ]; then
  if [ "${FORCE_REBUILD}" = false ]; then
    echo "[dry-run] ssh ${SSH_TARGET} \"sudo -n docker image inspect '${IMAGE_REF}' >/dev/null 2>&1\""
    echo "[dry-run] if image exists, build is skipped"
  fi
  echo "[dry-run] ssh ${SSH_TARGET} \"export GIT_SSH_COMMAND='ssh -i ${REMOTE_GIT_KEY_PATH} -o IdentitiesOnly=yes'; cd '${REMOTE_BUILD_WORKSPACE}'; git fetch --all --tags --prune; git checkout --force '${HEAD_FULL_SHA}'; git submodule sync --recursive; git submodule update --init --recursive; COMPOSER_HOME='${REMOTE_COMPOSER_HOME}' '${REMOTE_COMPOSER_PATH}' install --no-interaction --prefer-dist; sudo -n docker build -t '${IMAGE_REF}' -f Dockerfile.prod .\""
  exit 0
fi

if [ "${FORCE_REBUILD}" = false ] && remote_image_exists; then
  echo "Build phase skipped."
  echo "- remote image already exists and matches current HEAD: ${IMAGE_REF}"
  exit 0
fi

run_remote_build

echo "Build phase complete."
echo "- image: ${IMAGE_REF}"
echo "- build host: ${SSH_TARGET}"
echo "- build workspace: ${REMOTE_BUILD_WORKSPACE}"
echo "- metadata: ${LOCAL_METADATA_PATH}"
echo "- release env: ${RELEASE_ENV_PATH}"
