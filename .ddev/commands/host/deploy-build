#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Build production image and create a release artifact tarball locally.
## Usage: deploy-build [--dry-run] [--image-tag=<tag>] [--force-rebuild]
## Example: ddev deploy-build --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
LOCAL_ARTIFACT_DIR="${PROJECT_ROOT}/.ddev/.artifacts"
RELEASE_ENV_PATH="${LOCAL_ARTIFACT_DIR}/release.env"
IMAGE_REPOSITORY="bb-platform-drupal"
REMOTE_RELEASE_DIR="/home/bevan/workspace/bb-platform-prod/releases"

DRY_RUN=false
FORCE_REBUILD=false
IMAGE_TAG="git-$(git -C "${PROJECT_ROOT}" rev-parse --short=12 HEAD)"

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --image-tag=*)
      IMAGE_TAG="${arg#*=}"
      ;;
    --force-rebuild)
      FORCE_REBUILD=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

IMAGE_REF="${IMAGE_REPOSITORY}:${IMAGE_TAG}"
ARTIFACT_FILE="${IMAGE_REPOSITORY}-${IMAGE_TAG}.tar.gz"
LOCAL_ARTIFACT_PATH="${LOCAL_ARTIFACT_DIR}/${ARTIFACT_FILE}"
REMOTE_ARTIFACT_PATH="${REMOTE_RELEASE_DIR}/${ARTIFACT_FILE}"

write_release_env() {
  mkdir -p "${LOCAL_ARTIFACT_DIR}"
  cat > "${RELEASE_ENV_PATH}" <<VARS
# Generated by ddev deploy-build
PROJECT_ROOT=${PROJECT_ROOT}
IMAGE_REPOSITORY=${IMAGE_REPOSITORY}
IMAGE_TAG=${IMAGE_TAG}
IMAGE_REF=${IMAGE_REF}
ARTIFACT_FILE=${ARTIFACT_FILE}
LOCAL_ARTIFACT_PATH=${LOCAL_ARTIFACT_PATH}
REMOTE_RELEASE_DIR=${REMOTE_RELEASE_DIR}
REMOTE_ARTIFACT_PATH=${REMOTE_ARTIFACT_PATH}
VARS
}

print_plan() {
  echo "Build phase"
  echo "- image: ${IMAGE_REF}"
  echo "- local artifact: ${LOCAL_ARTIFACT_PATH}"
  echo "- release env: ${RELEASE_ENV_PATH}"
  echo "- dry run: ${DRY_RUN}"
  echo "- force rebuild: ${FORCE_REBUILD}"
}

print_plan

if [ "${DRY_RUN}" = true ]; then
  write_release_env
  if [ -f "${LOCAL_ARTIFACT_PATH}" ] && [ "${FORCE_REBUILD}" = false ]; then
    echo "[dry-run] artifact already exists, would skip build: ${LOCAL_ARTIFACT_PATH}"
    echo "[dry-run] use --force-rebuild to force image build and artifact regeneration"
  else
    echo "[dry-run] docker build -t ${IMAGE_REF} -f ${PROJECT_ROOT}/Dockerfile.prod ${PROJECT_ROOT}"
    echo "[dry-run] docker save ${IMAGE_REF} | gzip > ${LOCAL_ARTIFACT_PATH}"
  fi
  exit 0
fi

write_release_env
if [ -f "${LOCAL_ARTIFACT_PATH}" ] && [ "${FORCE_REBUILD}" = false ]; then
  echo "Build phase skipped."
  echo "- artifact already exists: ${LOCAL_ARTIFACT_PATH}"
  echo "- use --force-rebuild to regenerate this artifact"
  exit 0
fi

docker build -t "${IMAGE_REF}" -f "${PROJECT_ROOT}/Dockerfile.prod" "${PROJECT_ROOT}"
docker save "${IMAGE_REF}" | gzip > "${LOCAL_ARTIFACT_PATH}"

echo "Build phase complete."
echo "- image: ${IMAGE_REF}"
echo "- artifact: ${LOCAL_ARTIFACT_PATH}"
echo "- release env: ${RELEASE_ENV_PATH}"
