#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Upload local content-sync export files to staging workspace.
## Usage: deploy-content-export-staging [--source=<path>] [--dry-run]
## Example: ddev deploy-content-export-staging --source=content/sync

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SSH_TARGET="bb-drupal-prod"
REMOTE_CONTENT_DIR="/home/bevan/workspace/bb-platform-staging/content/sync"
DRY_RUN=false
SOURCE_ARG=""

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --source=*)
      SOURCE_ARG="${arg#*=}"
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

resolve_source_path() {
  local input_path="$1"
  if [[ "$input_path" = /* ]]; then
    echo "$input_path"
  else
    echo "${PROJECT_ROOT}/${input_path}"
  fi
}

if [ -n "${SOURCE_ARG}" ]; then
  SOURCE_PATH="$(resolve_source_path "${SOURCE_ARG}")"
else
  SOURCE_PATH="${PROJECT_ROOT}/content/sync"
fi

if [ ! -d "${SOURCE_PATH}" ]; then
  echo "Source directory not found: ${SOURCE_PATH}"
  echo "Use --source=/path/to/content-sync-dir"
  exit 1
fi

echo "Content export upload phase (staging)"
echo "- source: ${SOURCE_PATH}/"
echo "- target: ${SSH_TARGET}:${REMOTE_CONTENT_DIR}/"
echo "- dry run: ${DRY_RUN}"

if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] ssh ${SSH_TARGET} mkdir -p ${REMOTE_CONTENT_DIR}"
  echo "[dry-run] rsync -av --progress ${SOURCE_PATH}/ ${SSH_TARGET}:${REMOTE_CONTENT_DIR}/"
  exit 0
fi

ssh "${SSH_TARGET}" "mkdir -p ${REMOTE_CONTENT_DIR}"
rsync -av --progress "${SOURCE_PATH}/" "${SSH_TARGET}:${REMOTE_CONTENT_DIR}/"

echo "Content export upload complete (staging)."
echo "- uploaded to: ${REMOTE_CONTENT_DIR}"
