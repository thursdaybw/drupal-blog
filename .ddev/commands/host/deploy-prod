#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Build, upload, and activate a production release on prod stack.
## Usage: deploy-prod [--dry-run] [--image-tag=<tag>] [--force-rebuild]
## Example: ddev deploy-prod --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
DRY_RUN=false
IMAGE_TAG_ARG=""
FORCE_REBUILD=false

run_low_priority() {
  if command -v ionice >/dev/null 2>&1 && command -v nice >/dev/null 2>&1; then
    ionice -c2 -n7 nice -n19 "$@"
    return
  fi
  if command -v nice >/dev/null 2>&1; then
    nice -n19 "$@"
    return
  fi
  "$@"
}

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --image-tag=*)
      IMAGE_TAG_ARG="$arg"
      ;;
    --force-rebuild)
      FORCE_REBUILD=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

resolve_git_context() {
  local head_full_sha head_short_sha git_branch working_tree_dirty origin_main_sha head_vs_origin counts ahead_count behind_count
  head_full_sha="$(git -C "${PROJECT_ROOT}" rev-parse HEAD)"
  head_short_sha="$(git -C "${PROJECT_ROOT}" rev-parse --short=12 HEAD)"
  git_branch="$(git -C "${PROJECT_ROOT}" rev-parse --abbrev-ref HEAD)"
  if [ -n "$(git -C "${PROJECT_ROOT}" status --short --untracked-files=no)" ]; then
    working_tree_dirty=true
  else
    working_tree_dirty=false
  fi

  origin_main_sha=""
  head_vs_origin="origin/main unavailable"
  if git -C "${PROJECT_ROOT}" rev-parse --verify origin/main >/dev/null 2>&1; then
    origin_main_sha="$(git -C "${PROJECT_ROOT}" rev-parse origin/main)"
    counts="$(git -C "${PROJECT_ROOT}" rev-list --left-right --count HEAD...origin/main)"
    ahead_count="${counts%%$'\t'*}"
    behind_count="${counts##*$'\t'}"
    if [ "${ahead_count}" -gt 0 ] && [ "${behind_count}" -gt 0 ]; then
      head_vs_origin="diverged (+${ahead_count}/-${behind_count})"
    elif [ "${ahead_count}" -gt 0 ]; then
      head_vs_origin="ahead (+${ahead_count})"
    elif [ "${behind_count}" -gt 0 ]; then
      head_vs_origin="behind (-${behind_count})"
    else
      head_vs_origin="equal"
    fi
  fi

  echo "Deploy-prod phases: build -> upload -> activate(prod)"
  echo "- pwd: $(pwd)"
  echo "- project root: ${PROJECT_ROOT}"
  echo "- git branch: ${git_branch}"
  echo "- git HEAD: ${head_full_sha}"
  echo "- git HEAD short: ${head_short_sha}"
  echo "- working tree dirty: ${working_tree_dirty}"
  if [ -n "${origin_main_sha}" ]; then
    echo "- origin/main: ${origin_main_sha}"
    echo "- HEAD vs origin/main: ${head_vs_origin}"
  else
    echo "- origin/main: unavailable"
  fi
  if [[ "${head_vs_origin}" == ahead* ]]; then
    echo "Warning: local HEAD is ahead of origin/main; production deploy will use the local committed HEAD."
  fi
}

BUILD_ARGS=()
COMMON_ARGS=()

if [ -n "${IMAGE_TAG_ARG}" ]; then
  BUILD_ARGS+=("${IMAGE_TAG_ARG}")
fi

if [ "${FORCE_REBUILD}" = true ]; then
  BUILD_ARGS+=("--force-rebuild")
fi

if [ "${DRY_RUN}" = true ]; then
  BUILD_ARGS+=("--dry-run")
  COMMON_ARGS+=("--dry-run")
fi

resolve_git_context
echo "Running deploy phases with low host scheduling priority (ionice/nice when available)."
run_low_priority "$(dirname "$0")/deploy-verify" "${COMMON_ARGS[@]}"
run_low_priority "$(dirname "$0")/deploy-build" "${BUILD_ARGS[@]}"
run_low_priority "$(dirname "$0")/deploy-upload" "${COMMON_ARGS[@]}"
run_low_priority "$(dirname "$0")/deploy-prod-activate" "${COMMON_ARGS[@]}"

echo "Production deployment pipeline complete."
