#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Activate built release image on production stack.
## Usage: deploy-prod-activate [--dry-run]
## Example: ddev deploy-prod-activate --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RELEASE_ENV_PATH="${PROJECT_ROOT}/.ddev/.artifacts/release.env"
ANSIBLE_INVENTORY="${PROJECT_ROOT}/ops/ansible/inventory.ini"
ANSIBLE_PLAYBOOK="${PROJECT_ROOT}/ops/ansible/deploy_image.yml"
DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

fail() {
  echo "$1" >&2
  exit 1
}

resolve_git_context() {
  CURRENT_HEAD_FULL_SHA="$(git -C "${PROJECT_ROOT}" rev-parse HEAD)"
  CURRENT_HEAD_SHORT_SHA="$(git -C "${PROJECT_ROOT}" rev-parse --short=12 HEAD)"
}

validate_release_context() {
  if [ ! -f "${RELEASE_ENV_PATH}" ]; then
    fail "Release metadata not found: ${RELEASE_ENV_PATH}. Run: ddev deploy-build"
  fi

  # shellcheck source=/dev/null
  source "${RELEASE_ENV_PATH}"

  if [ "${HEAD_FULL_SHA:-}" != "${CURRENT_HEAD_FULL_SHA}" ]; then
    fail "Activate phase aborted. release.env HEAD_FULL_SHA ${HEAD_FULL_SHA:-missing} does not match current HEAD ${CURRENT_HEAD_FULL_SHA}. Run: ddev deploy-build"
  fi
  if [ "${HEAD_SHORT_SHA:-}" != "${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Activate phase aborted. release.env HEAD_SHORT_SHA ${HEAD_SHORT_SHA:-missing} does not match current HEAD short ${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build"
  fi
  if [ ! -f "${LOCAL_METADATA_PATH:-}" ]; then
    if [ "${DRY_RUN}" = true ]; then
      return
    fi
    fail "Activate phase aborted. Build metadata not found: ${LOCAL_METADATA_PATH:-missing}. Run: ddev deploy-build --force-rebuild"
  fi

  # shellcheck source=/dev/null
  source "${LOCAL_METADATA_PATH}"

  if [ "${HEAD_FULL_SHA:-}" != "${CURRENT_HEAD_FULL_SHA}" ]; then
    fail "Activate phase aborted. Build metadata HEAD_FULL_SHA ${HEAD_FULL_SHA:-missing} does not match current HEAD ${CURRENT_HEAD_FULL_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
  if [ "${HEAD_SHORT_SHA:-}" != "${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Activate phase aborted. Build metadata HEAD_SHORT_SHA ${HEAD_SHORT_SHA:-missing} does not match current HEAD short ${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
  if [ "${IMAGE_TAG:-}" != "git-${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Activate phase aborted. Build metadata IMAGE_TAG ${IMAGE_TAG:-missing} does not match expected git-${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
}

resolve_git_context
validate_release_context

echo "Activate phase (prod)"
echo "- image: ${IMAGE_REF}"
echo "- build/runtime host image: ${IMAGE_REF}"
echo "- metadata: ${LOCAL_METADATA_PATH}"
echo "- dry run: ${DRY_RUN}"

if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] ansible-playbook -i ${ANSIBLE_INVENTORY} ${ANSIBLE_PLAYBOOK} -e deploy_env=prod -e release_image_ref=${IMAGE_REF}"
  exit 0
fi

ansible-playbook \
  -i "${ANSIBLE_INVENTORY}" \
  "${ANSIBLE_PLAYBOOK}" \
  -e "deploy_env=prod" \
  -e "release_image_ref=${IMAGE_REF}"

echo "Activate phase complete (prod)."
echo "- active image: ${IMAGE_REF}"
