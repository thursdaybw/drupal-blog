#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Configure production nginx reverse proxy cutover to new prod stack.
## Usage: deploy-prod-proxy-cutover [--dry-run] [--disable-old-site=<filename>]
## Example: ddev deploy-prod-proxy-cutover --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ANSIBLE_INVENTORY="${PROJECT_ROOT}/ops/ansible/inventory.ini"
ANSIBLE_PLAYBOOK="${PROJECT_ROOT}/ops/ansible/cutover_prod_proxy.yml"
DRY_RUN=false
DISABLE_OLD_SITE_ARG=""

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --disable-old-site=*)
      DISABLE_OLD_SITE_ARG="${arg#*=}"
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

EXTRA_ARGS=()
if [ -n "${DISABLE_OLD_SITE_ARG}" ]; then
  EXTRA_ARGS+=("-e" "old_prod_site_filename=${DISABLE_OLD_SITE_ARG}")
fi

if [ "${DRY_RUN}" = true ]; then
  EXTRA_ARGS+=("--check")
fi

echo "Prod proxy cutover"
echo "- playbook: ${ANSIBLE_PLAYBOOK}"
if [ -n "${DISABLE_OLD_SITE_ARG}" ]; then
  echo "- disable old site symlink: ${DISABLE_OLD_SITE_ARG}"
fi
echo "- dry run: ${DRY_RUN}"

ansible-playbook -i "${ANSIBLE_INVENTORY}" "${ANSIBLE_PLAYBOOK}" "${EXTRA_ARGS[@]}"
