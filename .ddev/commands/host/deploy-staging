#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Build, upload, and activate a staging release.
## Usage: deploy-staging [--dry-run] [--image-tag=<tag>] [--force-rebuild]
## Example: ddev deploy-staging --dry-run

DRY_RUN=false
IMAGE_TAG_ARG=""
FORCE_REBUILD=false

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    --image-tag=*)
      IMAGE_TAG_ARG="$arg"
      ;;
    --force-rebuild)
      FORCE_REBUILD=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

BUILD_ARGS=()
COMMON_ARGS=()

if [ -n "${IMAGE_TAG_ARG}" ]; then
  BUILD_ARGS+=("${IMAGE_TAG_ARG}")
fi

if [ "${FORCE_REBUILD}" = true ]; then
  BUILD_ARGS+=("--force-rebuild")
fi

if [ "${DRY_RUN}" = true ]; then
  BUILD_ARGS+=("--dry-run")
  COMMON_ARGS+=("--dry-run")
fi

echo "Deploy-staging phases: build -> upload -> activate(staging)"

"$(dirname "$0")/deploy-verify" "${COMMON_ARGS[@]}"
"$(dirname "$0")/deploy-build" "${BUILD_ARGS[@]}"
"$(dirname "$0")/deploy-upload" "${COMMON_ARGS[@]}"
"$(dirname "$0")/deploy-activate" "${COMMON_ARGS[@]}"

echo "Staging deployment pipeline complete."
