#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Upload the latest release artifact to production host.
## Usage: deploy-upload [--dry-run]
## Example: ddev deploy-upload --dry-run

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RELEASE_ENV_PATH="${PROJECT_ROOT}/.ddev/.artifacts/release.env"
SSH_TARGET="bb-drupal-prod"
DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    *)
      echo "Unknown argument: $arg"
      exit 1
      ;;
  esac
done

fail() {
  echo "$1" >&2
  exit 1
}

resolve_git_context() {
  CURRENT_HEAD_FULL_SHA="$(git -C "${PROJECT_ROOT}" rev-parse HEAD)"
  CURRENT_HEAD_SHORT_SHA="$(git -C "${PROJECT_ROOT}" rev-parse --short=12 HEAD)"
}

validate_release_context() {
  if [ ! -f "${RELEASE_ENV_PATH}" ]; then
    fail "Release metadata not found: ${RELEASE_ENV_PATH}. Run: ddev deploy-build"
  fi

  # shellcheck source=/dev/null
  source "${RELEASE_ENV_PATH}"

  if [ "${HEAD_FULL_SHA:-}" != "${CURRENT_HEAD_FULL_SHA}" ]; then
    fail "Upload phase aborted. release.env HEAD_FULL_SHA ${HEAD_FULL_SHA:-missing} does not match current HEAD ${CURRENT_HEAD_FULL_SHA}. Run: ddev deploy-build"
  fi
  if [ "${HEAD_SHORT_SHA:-}" != "${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Upload phase aborted. release.env HEAD_SHORT_SHA ${HEAD_SHORT_SHA:-missing} does not match current HEAD short ${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build"
  fi
  if [ ! -f "${LOCAL_METADATA_PATH:-}" ]; then
    if [ "${DRY_RUN}" = true ]; then
      return
    fi
    fail "Upload phase aborted. Artifact metadata not found: ${LOCAL_METADATA_PATH:-missing}. Run: ddev deploy-build --force-rebuild"
  fi

  # shellcheck source=/dev/null
  source "${LOCAL_METADATA_PATH}"

  if [ "${HEAD_FULL_SHA:-}" != "${CURRENT_HEAD_FULL_SHA}" ]; then
    fail "Upload phase aborted. Artifact metadata HEAD_FULL_SHA ${HEAD_FULL_SHA:-missing} does not match current HEAD ${CURRENT_HEAD_FULL_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
  if [ "${HEAD_SHORT_SHA:-}" != "${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Upload phase aborted. Artifact metadata HEAD_SHORT_SHA ${HEAD_SHORT_SHA:-missing} does not match current HEAD short ${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
  if [ "${IMAGE_TAG:-}" != "git-${CURRENT_HEAD_SHORT_SHA}" ]; then
    fail "Upload phase aborted. Artifact metadata IMAGE_TAG ${IMAGE_TAG:-missing} does not match expected git-${CURRENT_HEAD_SHORT_SHA}. Run: ddev deploy-build --force-rebuild"
  fi
}

prune_local_artifacts() {
  local keep_count=3
  local files=()
  local delete_list=()
  local artifact_path metadata_path

  shopt -s nullglob
  files=( "${PROJECT_ROOT}/.ddev/.artifacts/${IMAGE_REPOSITORY}-"*.tar.gz )
  shopt -u nullglob

  if [ "${#files[@]}" -eq 0 ]; then
    return
  fi

  IFS=$'\n' files=( $(ls -1t "${files[@]}") )

  if [ "${#files[@]}" -le "${keep_count}" ]; then
    return
  fi

  delete_list=( "${files[@]:${keep_count}}" )

  for artifact_path in "${delete_list[@]}"; do
    metadata_path="${artifact_path%.tar.gz}.meta"
    rm -f "${artifact_path}" "${metadata_path}"
    echo "- pruned local artifact: ${artifact_path}"
    if [ -f "${metadata_path}" ]; then
      echo "- pruned local metadata: ${metadata_path}"
    fi
  done
}

prune_remote_artifacts() {
  local keep_count=3

  ssh "${SSH_TARGET}" "
set -euo pipefail
mapfile -t files < <(
  find \"${REMOTE_RELEASE_DIR}\" -maxdepth 1 -type f -name \"${IMAGE_REPOSITORY}-*.tar.gz\" \
    -printf '%T@ %p\\n' | sort -nr | awk '{print \$2}'
)
if [ \${#files[@]} -le ${keep_count} ]; then
  exit 0
fi
for old_file in \"\${files[@]:${keep_count}}\"; do
  rm -f \"\${old_file}\" \"\${old_file%.tar.gz}.meta\"
  echo \"- pruned remote artifact: \${old_file}\"
done
"
}

resolve_git_context
validate_release_context

if [ ! -f "${LOCAL_ARTIFACT_PATH}" ] && [ "${DRY_RUN}" = false ]; then
  fail "Local artifact not found: ${LOCAL_ARTIFACT_PATH}. Run: ddev deploy-build"
fi

echo "Upload phase"
echo "- source: ${LOCAL_ARTIFACT_PATH}"
echo "- metadata: ${LOCAL_METADATA_PATH}"
echo "- target: ${SSH_TARGET}:${REMOTE_ARTIFACT_PATH}"
echo "- dry run: ${DRY_RUN}"

if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] ssh ${SSH_TARGET} mkdir -p ${REMOTE_RELEASE_DIR}"
  echo "[dry-run] rsync -av --progress ${LOCAL_ARTIFACT_PATH} ${SSH_TARGET}:${REMOTE_ARTIFACT_PATH}"
  echo "[dry-run] rsync -av --progress ${LOCAL_METADATA_PATH} ${SSH_TARGET}:${REMOTE_ARTIFACT_PATH%.tar.gz}.meta"
  echo "[dry-run] keep newest 3 local artifacts matching ${PROJECT_ROOT}/.ddev/.artifacts/${IMAGE_REPOSITORY}-*.tar.gz"
  echo "[dry-run] keep newest 3 remote artifacts matching ${REMOTE_RELEASE_DIR}/${IMAGE_REPOSITORY}-*.tar.gz"
  exit 0
fi

ssh "${SSH_TARGET}" "mkdir -p ${REMOTE_RELEASE_DIR}"
rsync -av --progress "${LOCAL_ARTIFACT_PATH}" "${SSH_TARGET}:${REMOTE_ARTIFACT_PATH}"
rsync -av --progress "${LOCAL_METADATA_PATH}" "${SSH_TARGET}:${REMOTE_ARTIFACT_PATH%.tar.gz}.meta"
prune_local_artifacts
prune_remote_artifacts

echo "Upload phase complete."
echo "- uploaded: ${REMOTE_ARTIFACT_PATH}"
