#!/usr/bin/env bash

set -euo pipefail

## #ddev-generated
## Description: Run mandatory verification checks before deployment build.
## Usage: deploy-verify [--dry-run]
## Example: ddev deploy-verify

DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=true
      ;;
    *)
      echo "Unknown argument: ${arg}"
      exit 1
      ;;
  esac
done

echo "Verify phase"
echo "- dry run: ${DRY_RUN}"
echo "- checks:"
echo "  1) drush command discovery"
echo "  2) ai listing fast pre-deploy suite"

if [ "${DRY_RUN}" = true ]; then
  echo "[dry-run] ddev drush list >/dev/null"
  echo "[dry-run] ddev test-ai-listing-fast"
  exit 0
fi

ddev drush list >/dev/null
ddev test-ai-listing-fast

echo "Verify phase complete."
