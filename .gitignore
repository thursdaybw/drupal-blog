# Ignore system files
.DS_Store
Thumbs.db

# Ignore Lando configuration
.lando.yml

# Ignore configuration files that may contain sensitive information.
html/sites/*/settings*.php

# Ignore paths that contain user-generated content.
html/sites/*/files
html/sites/*/private

# Ignore PhpStorm project files
.idea/

# Ignore Visual Studio Code settings
.vscode/

# Ignore contributed modules, themes, and libraries, since those should be handled by composer or drush
html/sites/all/modules/contrib/
html/modules/contrib/
html/modules/devel/
html/themes/contrib/
html/libraries/contrib/
html/sites/all/themes/contrib/
html/sites/all/libraries/
html/sites/default/default.services.yml

# Ignore core since you'd typically manage that with composer or drush as well
/html/core/

# Custom folders you might want to ignore
custom-folder/

# Composer managed dependencies
/vendor/

# Ignore SASS, LESS, etc., compiled files
*.css.map
*.js.map

/files/

backup.sql.gz
docker-compose.override.yml
html/sites/default/development.services.yml
/keys/
known_hosts
.env
gpt-oauth.yml
ops/compose/staging/.env
ops/compose/prod/.env
ops/compose/prod/secrets/id_rsa_vastai

# Phase 2 Cleanup - Local Environment & Temp Data
.ddev/
backups/
content/sync/
vllm-pool.json
phpunit.browser.xml
phpunit.dtt.xml
dtt_device_profiles.yaml-off
dtt_multi_device_test_base/
html/sites/simpletest/
pre-migration.backup.sql
