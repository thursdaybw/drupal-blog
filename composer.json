{
    "name": "drupal/recommended-project",
    "description": "Project template for Drupal projects with a relocated document root",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "git@github.com:thursdaybw/video_forge.git"
        },
        {
            "type": "vcs",
            "url": "git@github.com:thursdaybw/dtt_multi_device_test_base.git"
        }
    ],
    "require": {
        "composer/installers": "^2.0",
        "cweagans/composer-patches": "~1.0",
        "drupal/admin_toolbar": "^3.6",
        "drupal/commerce": "^3.0",
        "drupal/config_devel": "^1.9",
        "drupal/config_ignore": "^3.3",
        "drupal/config_split": "^2.0",
        "drupal/config_update": "^2.0@alpha",
        "drupal/content_sync": "^3.0",
        "drupal/core-composer-scaffold": "^10.1",
        "drupal/core-project-message": "^10.1",
        "drupal/core-recommended": "^10.1",
        "drupal/default_content": "^2.0@alpha",
        "drupal/dynamic_entity_reference": "^3.2",
        "drupal/jsonapi_extras": "^3.26",
        "drupal/markdown": "^3.1",
        "drupal/matomo": "^1.23",
        "drupal/metatag": "^2.0",
        "drupal/openai": "^1.0@alpha",
        "drupal/openapi_rest": "^2.0@RC",
        "drupal/openapi_ui": "^1.0@RC",
        "drupal/pathauto": "^1.11",
        "drupal/queue_ui": "^3.2",
        "drupal/recaptcha": "^3.2",
        "drupal/restui": "^1.21",
        "drupal/simple_oauth": "^5.2",
        "drupal/vani": "^10.0",
        "drupaltest/queue-runner-trait": "^1.2",
        "drush/drush": "^12.1",
        "league/commonmark": "^2.7",
        "thursdaybw/video_forge": "dev-main",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "wikimedia/composer-merge-plugin": true,
            "php-http/discovery": true,
            "cweagans/composer-patches": true
        },
        "sort-packages": true,
        "preferred-install": {
            "thursdaybw/video_forge": "source"
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "html/"
            }
        },
        "installer-paths": {
            "html/core": [
                "type:drupal-core"
            ],
            "html/libraries/{$name}": [
                "type:drupal-library"
            ],
            "html/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "html/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "html/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "html/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "html/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "html/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you\u2019ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/installing-drupal",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        },
        "patches": {
            "drupal/content_sync": {
                "https://www.drupal.org/project/content_sync/issues/3486660 - Fix FileEntityNormalizer::denormalize return type for file imports": "patches/content_sync-3486660-file-normalizer-denormalize-return-type.patch",
                "LOCAL PATCH - Support dynamic entity reference target_type during import": "patches/content_sync-dynamic-entity-reference-import-target-type-resolution.patch"
            }
        },
        "merge-plugin": {
            "include": [
                "composer.local.json",
                "extensions/*/composer.json"
            ],
            "recurse": true,
            "replace": true,
            "ignore-duplicates": false,
            "merge-dev": true,
            "merge-extra": true,
            "merge-extra-deep": false,
            "merge-replace": true,
            "merge-scripts": false
        }
    },
    "require-dev": {
        "behat/mink": "^1.11",
        "behat/mink-browserkit-driver": "^2.2",
        "behat/mink-selenium2-driver": "^1.4",
        "drupal/coder": "^8.3",
        "drupal/devel_entity_updates": "^5.0",
        "drupal/stage_file_proxy": "^3.1",
        "mikey179/vfsstream": "^1.6",
        "phpspec/prophecy-phpunit": "^2.4",
        "phpunit/phpunit": "^9",
        "squizlabs/php_codesniffer": "^3.9",
        "symfony/phpunit-bridge": "^7.3",
        "thursdaybw/dtt_multi_device_test_base": "dev-main",
        "weitzman/drupal-test-traits": "^2.6"
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist"
    }
}
