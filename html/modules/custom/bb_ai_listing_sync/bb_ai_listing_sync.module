<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_insert().
 */
function bb_ai_listing_sync_entity_insert(EntityInterface $entity): void {
  bb_ai_listing_sync_apply_legacy_payload_after_save($entity);
}

/**
 * Implements hook_entity_update().
 */
function bb_ai_listing_sync_entity_update(EntityInterface $entity): void {
  bb_ai_listing_sync_apply_legacy_payload_after_save($entity);
}

/**
 * Applies staged legacy table payload for imported bb_ai_listing entities.
 */
function bb_ai_listing_sync_apply_legacy_payload_after_save(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'bb_ai_listing') {
    return;
  }

  $listingId = (int) $entity->id();
  $listingUuid = (string) $entity->uuid();
  if ($listingId <= 0 || $listingUuid === '') {
    return;
  }

  /** @var \Drupal\bb_ai_listing_sync\Service\LegacyTableSyncService $legacySync */
  $legacySync = \Drupal::service('bb_ai_listing_sync.legacy_table_sync');
  $legacySummary = $legacySync->applyPayloadForListing($listingUuid, $listingId);

  /** @var \Drupal\bb_ai_listing_sync\Service\ListingGraphPruneService $graphPrune */
  $graphPrune = \Drupal::service('bb_ai_listing_sync.listing_graph_prune');
  $pruneSummary = $graphPrune->applyPayloadForListing($listingUuid, $listingId);

  $legacyApplied = (($legacySummary['legacy_link_upserts'] ?? 0) > 0) || (($legacySummary['legacy_listing_upserts'] ?? 0) > 0);
  $graphApplied = (($pruneSummary['bundle_item_deletes'] ?? 0) > 0)
    || (($pruneSummary['inventory_sku_deletes'] ?? 0) > 0)
    || (($pruneSummary['publication_deletes'] ?? 0) > 0)
    || (($pruneSummary['listing_image_deletes'] ?? 0) > 0);

  if ($legacyApplied) {
    \Drupal::logger('bb_ai_listing_sync')->notice(
      'Applied legacy payload for listing @listing_id (@listing_uuid): link upserts=@link_upserts listing upserts=@listing_upserts',
      [
        '@listing_id' => $listingId,
        '@listing_uuid' => $listingUuid,
        '@link_upserts' => (int) ($legacySummary['legacy_link_upserts'] ?? 0),
        '@listing_upserts' => (int) ($legacySummary['legacy_listing_upserts'] ?? 0),
      ]
    );
  }

  if ($graphApplied) {
    \Drupal::logger('bb_ai_listing_sync')->notice(
      'Pruned listing graph drift for listing @listing_id (@listing_uuid): bundle_item_deletes=@bundle_item_deletes inventory_sku_deletes=@inventory_sku_deletes publication_deletes=@publication_deletes listing_image_deletes=@listing_image_deletes',
      [
        '@listing_id' => $listingId,
        '@listing_uuid' => $listingUuid,
        '@bundle_item_deletes' => (int) ($pruneSummary['bundle_item_deletes'] ?? 0),
        '@inventory_sku_deletes' => (int) ($pruneSummary['inventory_sku_deletes'] ?? 0),
        '@publication_deletes' => (int) ($pruneSummary['publication_deletes'] ?? 0),
        '@listing_image_deletes' => (int) ($pruneSummary['listing_image_deletes'] ?? 0),
      ]
    );
  }
}
