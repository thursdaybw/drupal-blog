<div class="bb-linktree-page">
  <div class="bb-linktree-page__inner">
    <header class="bb-linktree-page__header">
      <h1 class="bb-linktree-page__title">{{ page.title }}</h1>
      {% if intro %}
        <div class="bb-linktree-page__intro">{{ intro }}</div>
      {% endif %}
    </header>

    <div class="bb-linktree-page__items">
      {% for item in items %}
        <a
          class="bb-linktree-page__item"
          href="{{ item.url }}"
          {% if item.target %}
            target="{{ item.target }}"
          {% endif %}
          {% if item.rel %}
            rel="{{ item.rel }}"
          {% endif %}
        >
          <span class="bb-linktree-page__item-title">{{ item.label }}</span>
          {% if item.description %}
            <span class="bb-linktree-page__item-description">{{ item.description }}</span>
          {% endif %}
          <span class="bb-linktree-page__item-meta">{{ item.meta_label }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</div>
