# Copy this file to `ops/compose/prod/.env` on your laptop.
# Do not commit real secrets.

APP_ENV=prod

# `deploy-prod-activate` updates this value automatically each release.
APP_IMAGE=bb-platform-drupal:git-replace-me
APP_PORT=18081
MYSQL_VOLUME_NAME=bb-platform-prod_mysql_data
DRUSH_OPTIONS_URI=https://www.bevansbench.com

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_USER=prod_db_user
MYSQL_PASSWORD=replace-with-strong-user-password
MYSQL_DATABASE=prod_db_name

# eBay connector settings (environment-specific).
EBAY_CONNECTOR_ENVIRONMENT=production
EBAY_CONNECTOR_PRODUCTION_CLIENT_ID=
EBAY_CONNECTOR_PRODUCTION_CLIENT_SECRET=
EBAY_CONNECTOR_PRODUCTION_RU_NAME=
EBAY_CONNECTOR_SANDBOX_CLIENT_ID=
EBAY_CONNECTOR_SANDBOX_CLIENT_SECRET=
EBAY_CONNECTOR_SANDBOX_RU_NAME=

# Vast runtime credentials for compute_orchestrator pool acquire/release.
# VAST_API_KEY is consumed via settings.php override into Drupal config.
# VAST_SSH_KEY_PATH must be readable inside the appserver container.
# VAST_SSH_KEY_HOST_PATH points at the host-side key file mounted into appserver.
VAST_API_KEY=
VAST_SSH_KEY_HOST_PATH=./secrets/id_rsa_vastai
VAST_SSH_KEY_PATH=/home/http/.ssh/id_rsa_vastai
