# Copy this file to `ops/compose/prod/.env` on your laptop.
# Do not commit real secrets.

APP_ENV=prod

# `deploy-prod-activate` updates this value automatically each release.
APP_IMAGE=bb-platform-drupal:git-replace-me

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_USER=prod_db_user
MYSQL_PASSWORD=replace-with-strong-user-password
MYSQL_DATABASE=prod_db_name
