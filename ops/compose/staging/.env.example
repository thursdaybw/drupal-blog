# Copy this file to `ops/compose/staging/.env` on your laptop.
# Do not commit real secrets.

APP_ENV=staging

# `deploy-activate` updates this value automatically each release.
APP_IMAGE=bb-platform-drupal:git-replace-me

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_USER=staging_db_user
MYSQL_PASSWORD=replace-with-strong-user-password
MYSQL_DATABASE=staging_db_name
